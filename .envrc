# Load devbox environment
eval "$(devbox shellenv)"

# Set Android SDK path (adjust if needed)
export ANDROID_HOME="${ANDROID_HOME:-$HOME/Android/Sdk}"
export ANDROID_SDK_ROOT="${ANDROID_SDK_ROOT:-$HOME/Android/Sdk}"

# Add Android SDK tools to PATH
export PATH="$ANDROID_HOME/platform-tools:$ANDROID_HOME/cmdline-tools/latest/bin:$PATH"

# Set Gradle options for better performance
export GRADLE_OPTS="-Xmx2048m -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=UTF-8"

# Enable Gradle daemon
export GRADLE_USER_HOME="${GRADLE_USER_HOME:-$HOME/.gradle}"

echo "✓ MNN Android SDK development environment loaded"
