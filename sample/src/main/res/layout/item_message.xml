<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/message_background"
        android:layout_gravity="start"
        android:maxWidth="300dp"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Image thumbnail: shown only when message carries an image -->
        <ImageView
            android:id="@+id/messageImage"
            android:layout_width="200dp"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="6dp"
            android:visibility="gone"
            android:contentDescription="Attached image" />

        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3"
            android:text="Sample message" />

        <!-- Thinking disclosure: shown when model emitted a think block -->
        <TextView
            android:id="@+id/thinkingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🧠 Show reasoning"
            android:textColor="#8B6914"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/thinkingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#FFF8E1"
            android:padding="6dp"
            android:textColor="#5D4037"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.2"
            android:visibility="gone" />

        <TextView
            android:id="@+id/timestampText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            android:text="10:30 AM" />

    </LinearLayout>

</LinearLayout>
